# Slack (from api.slack.com → your app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Gemini API — FREE tier (aistudio.google.com → Get API key)
GEMINI_API_KEY=AQ.... (new format; older keys start with AIza — both work)

# Supabase storage (supabase.com → project → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=...  # service_role key (secret) — NOT the anon key

# Admin page password (you choose)
ADMIN_PASSWORD=...

# Optional overrides
CHECKIN_CHANNEL=C0A71RYLS9E
